      "CreateFile(*)", 
      "Bash(npx vue-tsc:*)",
      "Bash(cargo check:*)",
      "Bash(npm run:*)",
      "WebFetch(domain:feishu.doubao.com)",
      "WebSearch",
      "WebFetch(domain:gitee.com)",
      "WebFetch(domain:help.gitee.com)",
      "Bash(git *)",
      "Bash(npx tsc *)"
    ]
  }
}
